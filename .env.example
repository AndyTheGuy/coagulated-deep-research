# ==============================================================================
# Ultimate Deep Researcher - Environment Configuration Template
# Copy this file to `.env` and fill in your actual values.
# ==============================================================================

# General Configuration
ENV=development
LOG_LEVEL=INFO

# Docker Infrastructure Configuration (Set secure random hex values in production)
SEARXNG_SECRET=ultimatedeepresearchersecretkey
FREE_LLM_API_ENCRYPTION_KEY=c3ecb15f917578a1bc1bdf96b83ba56f4d1e2e1ef2322a36b56834161a0d8591

# Google Vertex AI (Primary Provider for Critical Tasks)
# Authenticates via Google Application Default Credentials (ADC)
# Run `gcloud auth application-default login` to authenticate locally.
GCP_PROJECT_ID=agenticuse
GCP_LOCATION=global

# FreeLLMAPI Configuration (Standard/Bulk Tasks)
# Self-hosted Docker endpoint
FREE_LLM_API_BASE_URL=http://localhost:8000/v1
FREE_LLM_API_KEY=mock-api-key
USE_FREE_LLM_API=False

# LLM Routing - Model Mapping
CRITICAL_MODEL=gemini-3.5-flash
STANDARD_MODEL=auto
BULK_MODEL=auto

# Web Search Configuration
SEARXNG_URL=http://localhost:8080

# Vector Database (Qdrant)
# By default, runs in-memory. Set host/port if running via Docker.
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
